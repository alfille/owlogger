# /etc/owlogger/owlogger.env
#
# Runtime secrets and settings for the owlogger systemd service.
# Loaded via EnvironmentFile= in owlogger.service.
#
# Security:
#   sudo chown owlogger:owlogger /etc/owlogger/owlogger.env
#   sudo chmod 600               /etc/owlogger/owlogger.env
#
# Priority: these values override the TOML file (/etc/owlogger/owlogger.toml).
# Comment out any line to fall back to the TOML value or built-in default.

# ── JWT secret ────────────────────────────────────────────────────────────
# Required for POST/PUT data ingestion unless OWLOGGER_NO_PASSWORD=true.
# Generate:  python3 -c "import secrets; print(secrets.token_hex(32))"
OWLOGGER_TOKEN=change-me-to-a-long-random-secret

# ── Database location ─────────────────────────────────────────────────────
OWLOGGER_DATABASE=/var/lib/owlogger/logger_data.db

# ── Alternate TOML path (optional) ───────────────────────────────────────
# OWLOGGER_CONFIG=/etc/owlogger/owlogger.toml

# ── Debug logging (uncomment to enable) ──────────────────────────────────
# OWLOGGER_DEBUG=true

# ── Disable Basic-Auth (testing only — do not use in production) ─────────
# OWLOGGER_NO_PASSWORD=true
